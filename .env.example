# Tamipee Integrated Farms - Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ===== Django Core Settings =====
# Generate a strong secret key with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=replace-with-a-strong-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===== Database (PostgreSQL for production) =====
# Uncomment and configure for production:
# DATABASE_URL=postgresql://user:password@localhost:5432/tamipee_db

# ===== Supabase / S3-compatible storage =====
# When using Supabase Storage for image/media files, enable these values.
USE_S3_STORAGE=true
AWS_STORAGE_BUCKET_NAME=public
AWS_S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1
AWS_ACCESS_KEY_ID=your_supabase_storage_key_id
AWS_SECRET_ACCESS_KEY=your_supabase_storage_secret_key
# Optional public URL if you want media to be served from Supabase directly
# MEDIA_URL=https://<project-ref>.supabase.co/storage/v1/object/public/public/

# ===== Paystack Payment Gateway =====
# Get your keys from https://dashboard.paystack.com/#/settings/developer
# Use test keys for development, live keys for production
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# ===== Email Configuration (SendGrid SMTP) =====
# Create a free SendGrid account, verify a sender, then create an API key.
# SMTP username is always: apikey
EMAIL_HOST=smtp.sendgrid.net
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key-here
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Tamipee Integrated Farms <verified-sender@yourdomain.com>

# ===== Security Settings (Production) =====
# Only active when DJANGO_DEBUG=False
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_X_FRAME_OPTIONS=DENY

# ===== Development Override =====
# Uncomment these for local development:
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# DJANGO_CSRF_TRUSTED_ORIGINS=
# DJANGO_SECURE_SSL_REDIRECT=False
# DJANGO_SESSION_COOKIE_SECURE=False
# DJANGO_CSRF_COOKIE_SECURE=False
